// Prisma schema for Shreepathy & Co
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Tier {
  Silver
  Gold
  Platinum
}

enum LeadStatus {
  New
  Contacted
  Converted
  Lost
}

enum StockStatus {
  in_stock
  low
  out_of_stock
}

// ─── Catalogue ────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  sortOrder Int
  products  Product[]
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  description String?
  products    Product[]
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  brandId     String
  categoryId  String
  description String
  images      String[]
  modelGlb    String?
  stockStatus StockStatus     @default(in_stock)
  isFeatured  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  brand       Brand           @relation(fields: [brandId], references: [id])
  category    Category        @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String
  price     Float?
  image     String?

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model CustomerProfile {
  id              String        @id @default(cuid())
  userId          String?       @unique
  businessName    String
  contactName     String
  phone           String
  email           String
  tier            Tier          @default(Silver)
  pointsBalance   Int           @default(0)
  referralCode    String        @unique
  birthday        DateTime?
  registeredAt    DateTime      @default(now())

  orders          Order[]
  loyaltyEntries  LoyaltyEntry[]
  commsLogs       CommsLog[]
  followups       Followup[]
  referralsMade   Referral[]    @relation("referrer")
  referralsReceived Referral[]  @relation("referred")
}

model Order {
  id            String          @id @default(cuid())
  customerId    String
  totalValue    Float
  status        String          @default("logged")
  loggedBy      String?
  createdAt     DateTime        @default(now())

  customer      CustomerProfile @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  loyaltyEntries LoyaltyEntry[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  name       String
  size       String
  qty        Int
  unitValue  Float

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model LoyaltyEntry {
  id           String          @id @default(cuid())
  customerId   String
  pointsDelta  Int
  reason       String
  orderId      String?
  createdAt    DateTime        @default(now())

  customer     CustomerProfile @relation(fields: [customerId], references: [id])
  order        Order?          @relation(fields: [orderId], references: [id])
}

model Referral {
  id             String          @id @default(cuid())
  referrerId     String
  referredId     String?
  code           String
  status         String          @default("pending")
  pointsAwarded  Int             @default(0)
  createdAt      DateTime        @default(now())

  referrer       CustomerProfile  @relation("referrer", fields: [referrerId], references: [id])
  referred       CustomerProfile? @relation("referred", fields: [referredId], references: [id])
}

// ─── Sales / Lead ─────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  source       String
  status       LeadStatus @default(New)
  name         String
  phone        String
  businessName String?
  notes        String?
  assignedTo   String?
  createdAt    DateTime   @default(now())

  commsLogs    CommsLog[]
  followups    Followup[]
}

model CommsLog {
  id         String           @id @default(cuid())
  customerId String?
  leadId     String?
  type       String
  summary    String
  createdAt  DateTime         @default(now())

  customer   CustomerProfile? @relation(fields: [customerId], references: [id])
  lead       Lead?            @relation(fields: [leadId], references: [id])
}

model Followup {
  id         String           @id @default(cuid())
  customerId String?
  leadId     String?
  dueDate    DateTime
  note       String
  done       Boolean          @default(false)

  customer   CustomerProfile? @relation(fields: [customerId], references: [id])
  lead       Lead?            @relation(fields: [leadId], references: [id])
}

// ─── Public / Content ─────────────────────────────────────────────────────────

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  business  String?
  products  String
  quantity  String?
  location  String?
  message   String?
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Faq {
  id        String @id @default(cuid())
  question  String
  answer    String
  sortOrder Int    @default(0)
}

model SiteContent {
  id             String @id @default("singleton")
  heroHeadline   String
  heroSubtext    String
  ctaLabel       String
  aboutCopy      String
  contactPhone   String
  contactEmail   String
  contactAddress String
  mapEmbedUrl    String
}

model Settings {
  id              String @id @default("singleton")
  whatsappNumber  String
  businessName    String
  businessHours   String
  seoTitle        String
  seoDescription  String
}
